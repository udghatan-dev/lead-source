  "scripts": {
    "analyze": "source-map-explorer build/static/js/main.*",
    "start": "react-scripts start && cra-append-sw --mode dev ./public/custom-sw.js",
    "build": "GENERATE_SOURCEMAP=false react-scripts build --max_old_space_size=8000 build",
    "buildDev": "GENERATE_SOURCEMAP=false react-scripts build --max_old_space_size=8000 build && cra-append-sw --skip-compile ./public/custom-sw.js",
    "winBuild": "set \"GENERATE_SOURCEMAP=false\" && react-scripts build --max_old_space_size=8000 build && cra-append-sw --skip-compile ./public/custom-sw.js",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "format": "prettier --write \"**/*.{js,jsx,json,md,html,css,less,scss}\""
  },
  "browser": {
    "fs": false
  },
  "babelOptions": {
    "presets": [
      "@babel/preset-react",
      {
        "runtime": "automatic"
      }
    ]
  },
  "eslintConfig": {
    "extends": [
      "eslint:recommended",
      "plugin:react/recommended",
      "react-app"
    ],
    "parser": "@babel/eslint-parser",
    "parserOptions": {
      "requireConfigFile": false,
      "ecmaVersion": 2020,
      "sourceType": "module",
      "ecmaFeatures": {
        "jsx": true
      }
    },
    "env": {
      "browser": true,
      "es6": true
    },
    "globals": {
      "$": true
    },
    "settings": {
      "react": {
        "version": "^17.0.1"
      }
    },
    "rules": {
      "semi": 0,
      "react/no-unescaped-entities": 0,
      "react/react-in-jsx-scope": "off",
      "react/prop-types": "off",
      "no-unused-vars": "off",
      "no-extra-boolean-cast": 0
    }
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "resolutions": {
    "moment": "2.29.1",
    "autoprefixer": "10.4.5"
  },
  "devDependencies": {
    "ajv": "^7.2.4",
    "babel-plugin-prismjs": "^2.1.0",
    "webpack-bundle-analyzer": "^4.6.1"
  },
  "overrides": {
    "autoprefixer": "10.4.5"
  },
  "buildCode": 1718081453338
}
